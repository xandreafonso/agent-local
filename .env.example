# ── Model Selection ───────────────────────────────────
# Formato: AGENT_COMMAND_MODEL=provider/model-id
#
# Providers com SDK direto:
#   openai/gpt-4o-mini
#   openai/gpt-5.2
#   deepseek/deepseek-v4-pro
#   anthropic/claude-sonnet-4-6
#   zhipu/glm-4-plus     (ou z.ai/glm-4-plus)
#
# Fallback automático via OpenRouter:
#   moonshotai/kimi-k2.6
#   google/gemini-2.5-pro
#   ... qualquer provider/modelo não listado acima
AGENT_COMMAND_MODEL=openai/gpt-4o-mini

# ── API Keys (preencha as que for usar) ────────────────
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ZHIPU_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
